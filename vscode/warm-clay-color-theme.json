    "titleBar.activeForeground": "#e7e0de",
    "titleBar.inactiveBackground": "#2a1c17",
    "titleBar.inactiveForeground": "#5a3d35",

    "statusBar.background": "#3a2620",
    "statusBar.foreground": "#e7e0de",
